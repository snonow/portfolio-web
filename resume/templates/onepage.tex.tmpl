\newcommand{\doublecol}[4]{
  \begin{tabularx}{\textwidth}{@{} c X r @{}}
    \begin{tikzpicture}[baseline=(current bounding box.center)]
        \clip (0,0) circle (1.6cm);
        \node[anchor=center] at (0,0) {\includegraphics[width=3.2cm]{profile.jpg}};
    \end{tikzpicture}
    &
    \begin{tabular}[c]{@{\hspace{15pt}}l@{}}
        \fontsize{35}{45}\selectfont{\color{primary}{\textbf{\fullname}}} \\[5pt]
        \fontsize{15}{25}\selectfont{\textit{\subtitle}}
    \end{tabular}
    &
    \begin{tabular}[c]{@{}l@{}}
        {\small\phone} \\ {\small\email} \\ {\small\website} \\ {\small\linkedin} \\ {\small\github}
    \end{tabular}
  \end{tabularx}
}

\newcommand{\singlecol}[4]{
