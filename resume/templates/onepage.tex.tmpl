        \fontsize{35}{45}\selectfont{\color{primary}{{\textbf{\fullname}}}} \\
        \fontsize{15}{25}\selectfont{\textit{\subtitle}}
      \end{minipage}
    \end{tabular}} & {\begin{tabular}[c]{l}
      {\small#1} \\ {\small#2} \\ {\small#3} \\ {\small#4}
    \end{tabular}}
  \end{tabularx}
}

